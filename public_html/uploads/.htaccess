# Uploads — bloqueia execução de PHP (previne shell upload)
Options -Indexes

<FilesMatch "\.(php|phtml|php3|php4|php5|php7|php8|phar|cgi|pl|py|rb|sh)$">
    Require all denied
</FilesMatch>

# Permite apenas formatos de arquivo seguros
<FilesMatch "\.(pdf|doc|docx|jpg|jpeg|png|webp|gif)$">
    Require all granted
</FilesMatch>
