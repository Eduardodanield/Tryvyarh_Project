# ============================================================
# Trivya RH — Template de variáveis de ambiente
# Copie este arquivo para .env e preencha com seus dados reais
# NUNCA commite o arquivo .env no repositório
# ============================================================

# ----------------------------------------------------------
# Banco de Dados
# ----------------------------------------------------------
# ============================================================
# Trivya RH — Desenvolvimento Local (XAMPP)
# ============================================================

# Banco de Dados (XAMPP padrão)
DB_HOST=localhost
DB_NAME=trivya_rh
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Aplicação
APP_URL=http://localhost/trivya-rh
APP_ENV=development
APP_DEBUG=true

# SMTP — Desativado por enquanto (configuramos depois com Hostinger)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Trivya RH
SMTP_FROM_EMAIL=contato@trivyarh.com.br

# reCAPTCHA — Vamos gerar as chaves depois (deixa vazio agora)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Google Analytics — Configuramos quando subir pra produção
GA4_MEASUREMENT_ID=
